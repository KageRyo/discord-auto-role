# Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=replace-with-your-bot-token

# Optional: limit auto-role to a single guild/server.
DISCORD_GUILD_ID=123456789012345678

# Choose one role selector. `DISCORD_ROLE_ID` is recommended.
DISCORD_ROLE_ID=987654321098765432
DISCORD_ROLE_NAME=
